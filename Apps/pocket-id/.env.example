# Pocket ID - ZimaOS/CasaOS Marketplace Configuration

# User and Group IDs for container privilege level
# Use 1000:1000 for non-root, 0:0 for root (not recommended)
PUID=1000
PGID=1000

# System timezone
TZ=UTC

# Web UI Port (automatically assigned by ZimaOS/CasaOS)
# Default: 1411
WebUI_PORT=1411

# Optional: Database URL for PostgreSQL support
# Leave empty for default SQLite
# DATABASE_URL=postgresql://user:password@postgres:5432/pocket_id

# Optional: JWT secret for signing tokens
# Leave empty to generate automatically
# JWT_SECRET=your-secret-key-here

# Optional: CORS allowed origins
# CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Optional: Enable debug logging
# DEBUG=false
